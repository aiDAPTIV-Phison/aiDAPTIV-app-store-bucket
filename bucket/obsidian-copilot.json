{
    "version": "1.0.0",
    "description": "aiDAPTIV+ Integration for Obsidian - AI-powered assistant plugin with local LLM support",
    "homepage": "https://github.com/aiDAPTIV-Phison/aiDAPTIV-Integration-Obsidian",
    "url": [
