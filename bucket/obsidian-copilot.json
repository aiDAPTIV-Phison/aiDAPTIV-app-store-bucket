        "https://github.com/aiDAPTIV-Phison/aiDAPTIV-app-store-bucket/raw/refs/heads/main/script/obsidian-copilot/stop.ps1",
        "https://github.com/aiDAPTIV-Phison/aiDAPTIV-app-store-bucket/raw/refs/heads/main/script/obsidian-copilot/uninstall.ps1"
    ],
    "hash": [
        "F6516F034C11E6C9C413CBDEA45F5EE28CE99ECB256FB128FF09034D19F448AF",
        "fc20ce81e5835a5752e3d0351c29f416ca1ae6d5df937d7ff1c68f7670ec13e9",
        "5afde5b62644b6d32fb594bc66d490f08b6d3caa9632da489c34b2bc91711dac",
        "df605a799629ed2cea93aa444a9c03af7992847a8668b75b28f46f18de5778fe",
        "543750ba6163dba593c4348f9079005f8e8fb2947c091f11afc8108a3faf1d0e"
    ],
    "pre_install": [
        "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8",
        "Write-Host ''",
        "Write-Host '========================================' -ForegroundColor Cyan",
        "Write-Host 'aiDAPTIV+ Auto Installer for Obsidian' -ForegroundColor Cyan",
        "Write-Host '========================================' -ForegroundColor Cyan",
        "Write-Host ''",
        "$PluginSourceDir = Join-Path $dir 'aiDAPTIV-Integration-Obsidian'",
        "$PluginZip = Join-Path $dir 'aiDAPTIV-Integration-Obsidian.zip'",
        "if (Test-Path $PluginSourceDir) {",
        "  Write-Host '[OK] Plugin folder found!' -ForegroundColor Green",
        "} elseif (Test-Path $PluginZip) {",
        "  Write-Host '[OK] Plugin zip found!' -ForegroundColor Green",
        "} else {",
        "  Write-Host '[ERROR] Plugin source not found:' -ForegroundColor Red",
        "  Write-Host \"  Folder: $PluginSourceDir\" -ForegroundColor Red",
        "  Write-Host \"  Zip: $PluginZip\" -ForegroundColor Red",
        "  throw 'Plugin source not found'",
        "}",
        "Write-Host ''",
        "Write-Host '[INFO] Checking Obsidian installation...' -ForegroundColor Cyan",
        "$obsidianFound = $false",
        "$obsidianSearchPaths = @(",
        "  \"${env:LOCALAPPDATA}\\Obsidian\\Obsidian.exe\",",
        "  \"${env:LOCALAPPDATA}\\Programs\\Obsidian\\Obsidian.exe\",",
        "  \"${env:PROGRAMFILES}\\Obsidian\\Obsidian.exe\",",
        "  \"${env:PROGRAMFILES(x86)}\\Obsidian\\Obsidian.exe\",",
        "  \"${env:APPDATA}\\Obsidian\\Obsidian.exe\"",
        ")",
        "foreach ($p in $obsidianSearchPaths) { if (Test-Path $p) { $obsidianFound = $true; break } }",
        "if (-not $obsidianFound) {",
        "  try { $obsidianCmd = Get-Command 'Obsidian' -ErrorAction SilentlyContinue; if ($obsidianCmd) { $obsidianFound = $true } } catch { }",
        "}",
        "if (-not $obsidianFound) {",
        "  try {",
        "    $shortcut = Get-ChildItem -Path \"${env:APPDATA}\\Microsoft\\Windows\\Start Menu\\Programs\" -Recurse -Filter '*Obsidian*.lnk' -ErrorAction SilentlyContinue | Select-Object -First 1",
        "    if ($shortcut) { $obsidianFound = $true }",
        "  } catch { }",
        "}",
        "if ($obsidianFound) {",
        "  Write-Host '[OK] Obsidian is installed!' -ForegroundColor Green",
        "} else {",
        "  Write-Host '[ERROR] Obsidian is not installed!' -ForegroundColor Red",
        "  Write-Host 'Please install Obsidian first: https://obsidian.md/download' -ForegroundColor Yellow",
        "  throw 'Obsidian is not installed'",
        "}",
        "Write-Host ''",
        "$ObsidianConfig = Join-Path $env:APPDATA 'obsidian\\obsidian.json'",
        "if (Test-Path $ObsidianConfig) {",
        "  Write-Host '[OK] Obsidian config file found!' -ForegroundColor Green",
        "} else {",
        "  Write-Host '[WARNING] Obsidian config file not found. No Vaults to install to yet.' -ForegroundColor Yellow",
        "  Write-Host '[INFO] Plugin files will be ready. Please open Obsidian and create a Vault, then re-run the installer.' -ForegroundColor Yellow",
        "}"
    ],
    "installer": {
        "script": [
            "Write-Host ''",
            "Write-Host 'Scanning all your Vaults...' -ForegroundColor Cyan",
            "Write-Host ''",
            "$PluginSourceDir = Join-Path $dir 'aiDAPTIV-Integration-Obsidian'",
            "$PluginZip = Join-Path $dir 'aiDAPTIV-Integration-Obsidian.zip'",
            "$UseExtractedFolder = Test-Path $PluginSourceDir",
            "$ObsidianConfig = Join-Path $env:APPDATA 'obsidian\\obsidian.json'",
            "$vaultCount = 0",
            "$installedCount = 0",
            "$skippedCount = 0",
            "$errorCount = 0",
            "if (-not (Test-Path $ObsidianConfig)) {",
            "  Write-Host '[WARNING] No Obsidian config found. Skipping Vault installation.' -ForegroundColor Yellow",
            "} else {",
            "$obsidianConfigContent = Get-Content $ObsidianConfig -Raw | ConvertFrom-Json",
            "foreach ($vault in $obsidianConfigContent.vaults.PSObject.Properties) {",
            "  $vaultCount++",
            "  $vaultPath = $vault.Value.path",
            "  $vaultName = Split-Path $vaultPath -Leaf",
            "  Write-Host \"[$vaultCount] Checking Vault: $vaultName\" -ForegroundColor White",
            "  if (-not (Test-Path $vaultPath)) {",
            "    Write-Host '    [SKIP] Vault path does not exist' -ForegroundColor Yellow",
            "    continue",
            "  }",
            "  $obsidianDir = Join-Path $vaultPath '.obsidian'",
            "  $pluginsDir = Join-Path $obsidianDir 'plugins'",
            "  $pluginDir = Join-Path $pluginsDir 'aiDAPTIV-Integration-Obsidian'",
            "  $mainJs = Join-Path $pluginDir 'main.js'",
            "  $manifestJson = Join-Path $pluginDir 'manifest.json'",
            "  if ((Test-Path $pluginDir) -and (Test-Path $mainJs) -and (Test-Path $manifestJson)) {",
            "    Write-Host '    [SKIP] Plugin already installed' -ForegroundColor Green",
            "    $skippedCount++",
            "    continue",
            "  }",
            "  Write-Host '    [INSTALL] Installing plugin...' -ForegroundColor Cyan",
            "  try {",
            "    if (-not (Test-Path $obsidianDir)) { New-Item -ItemType Directory -Path $obsidianDir -Force | Out-Null }",
            "    if (-not (Test-Path $pluginsDir)) { New-Item -ItemType Directory -Path $pluginsDir -Force | Out-Null }",
            "    if (Test-Path $pluginDir) { Remove-Item -Path $pluginDir -Recurse -Force }",
            "    New-Item -ItemType Directory -Path $pluginDir -Force | Out-Null",
            "    if ($UseExtractedFolder) {",
            "      Copy-Item -Path \"$PluginSourceDir\\*\" -Destination $pluginDir -Recurse -Force",
            "    } else {",
            "      Expand-Archive -Path $PluginZip -DestinationPath $pluginDir -Force",
            "      $subfolderPath = Join-Path $pluginDir 'aiDAPTIV-Integration-Obsidian'",
            "      if (Test-Path $subfolderPath) {",
            "        Get-ChildItem -Path $subfolderPath | Move-Item -Destination $pluginDir -Force",
            "        Remove-Item -Path $subfolderPath -Recurse -Force",
            "      }",
            "    }",
            "    if ((Test-Path $mainJs) -and (Test-Path $manifestJson)) {",
            "      Write-Host '    [SUCCESS] Installation successful!' -ForegroundColor Green",
            "      $installedCount++",
            "    } else {",
            "      Write-Host '    [ERROR] Installation failed - missing required files' -ForegroundColor Red",
            "      $errorCount++",
            "    }",
            "  } catch {",
            "    Write-Host \"    [ERROR] Installation error: $($_.Exception.Message)\" -ForegroundColor Red",
            "    $errorCount++",
            "  }",
            "  Write-Host ''",
            "}",
            "}",
            "Write-Host '========================================' -ForegroundColor Cyan",
            "Write-Host 'Installation Complete!' -ForegroundColor Cyan",
            "Write-Host '========================================' -ForegroundColor Cyan",
            "Write-Host \"Total Vaults found: $vaultCount\" -ForegroundColor White",
            "Write-Host \"Newly installed: $installedCount\" -ForegroundColor Green",
            "Write-Host \"Already installed (skipped): $skippedCount\" -ForegroundColor Yellow",
            "if ($errorCount -gt 0) { Write-Host \"Installation failed: $errorCount\" -ForegroundColor Red }",
            "$global:ObsidianInstalledCount = $installedCount"
        ]
    },
    "post_install": [
        "Write-Host ''",
        "Write-Host '[INFO] Verifying plugin installation...' -ForegroundColor Cyan",
        "$ObsidianConfig = Join-Path $env:APPDATA 'obsidian\\obsidian.json'",
        "if (-not (Test-Path $ObsidianConfig)) {",
        "  Write-Host '[INFO] No Obsidian config found. Plugin files are ready in install directory.' -ForegroundColor Yellow",
        "  Write-Host '[INFO] Open Obsidian and create a Vault, then re-run the installer to deploy the plugin.' -ForegroundColor Yellow",
        "} else {",
        "  $obsidianConfigContent = Get-Content $ObsidianConfig -Raw | ConvertFrom-Json",
        "  $verifiedCount = 0",
        "  $totalCount = 0",
        "  foreach ($vault in $obsidianConfigContent.vaults.PSObject.Properties) {",
        "    $vaultPath = $vault.Value.path",
        "    if (-not (Test-Path $vaultPath)) { continue }",
        "    $totalCount++",
        "    $pluginDir = Join-Path $vaultPath '.obsidian\\plugins\\aiDAPTIV-Integration-Obsidian'",
        "    $mainJs = Join-Path $pluginDir 'main.js'",
        "    $manifestJson = Join-Path $pluginDir 'manifest.json'",
        "    if ((Test-Path $pluginDir) -and (Test-Path $mainJs) -and (Test-Path $manifestJson)) {",
        "      $verifiedCount++",
        "    }",
        "  }",
        "  if ($verifiedCount -eq $totalCount) {",
        "    Write-Host \"[SUCCESS] Plugin verified in all Vaults ($verifiedCount/$totalCount)\" -ForegroundColor Green",
        "  } else {",
        "    Write-Host \"[WARNING] Plugin verified in $verifiedCount/$totalCount Vaults\" -ForegroundColor Yellow",
        "  }",
        "}",
        "Write-Host ''",
        "Write-Host 'Installation script completed.' -ForegroundColor Green"
    ],
    "pre_uninstall": [
        "& \"$dir\\stop.ps1\"",
        "& \"$dir\\uninstall.ps1\""
    ]
}